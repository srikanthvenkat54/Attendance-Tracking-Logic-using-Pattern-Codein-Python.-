attendance = {} 
n = int(input("Enter number of students: ")) 
for i in range(1, n + 1): 
name = input(f"\nEnter name of student {i}: ") 
status = input("Enter attendance (P/A): ").strip().upper() 
    if status == "P": 
        attendance[name] = "Present" 
    elif status == "A": 
        attendance[name] = "Absent" 
    else: 
        print("Invalid input! Marking Absent by default.") 
        attendance[name] = "Absent" 
print("\n--- Attendance Report -----") 
present = 0 
absent = 0 
for name, status in attendance.items(): 
    print(name, ":", status) 
    if status == "Present": 
        present += 1 
    else: 
        absent += 1 
total = present + absent 
if total > 0: 
    percentage = (present / total) * 100 
else: 
    percentage = 0 
print("\nTotal Students:", total) 
print("Total Present:", present) 
print("Total Absent:", absent) 
print("Attendance Percentage:", round(percentage, 2), "%")
